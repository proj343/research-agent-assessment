# LLM Provider: "groq" (default, free cloud) or "ollama" (local)
LLM_PROVIDER=groq

# Groq API key — free at https://console.groq.com (no credit card required)
GROQ_API_KEY=your_groq_api_key_here

# Groq model (default: llama-3.3-70b-versatile; faster alternative: llama-3.1-8b-instant)
LLM_MODEL=llama-3.3-70b-versatile

# Ollama settings (only used when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2:3b

# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html (instant signup)
# Required only for questions about economic data (unemployment, GDP, interest rates)
FRED_API_KEY=your_fred_api_key_here
